# BMBCC Website - Public Vite Environment Template
# Copy this file to .env.local only for non-secret public build-time values.
# NEVER put passwords or tokens in VITE_* variables; Vite embeds them in browser JS.

# ============================================
# OPTIONAL: GitHub Auto-Save defaults
# ============================================
# The admin UI can auto-save content to GitHub via a Fine-grained PAT that you
# paste into the browser. The token is stored in that browser's localStorage only.
# Do not set a PAT here, because VITE_* values are public in the built site.
VITE_GITHUB_REPO=fongway94/BMBCCWebpage
VITE_AUTO_SAVE_GITHUB=false

# ============================================
# CLOUDFLARE PAGES SERVER-SIDE SECRETS
# ============================================
# Set these in Cloudflare Pages Dashboard > Settings > Environment Variables.
# Mark both as Secret. Do NOT prefix them with VITE_ and do NOT commit values.
#
# ADMIN_PASSWORD=generate-with: openssl rand -base64 18
# JWT_SECRET=generate-with: openssl rand -base64 32
