# BMBCC Website - Environment Variables Template
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git!

# ============================================
# REQUIRED FOR BUILD (Vite injects these at build time)
# ============================================

# Strong admin password (min 12 chars, mixed case, numbers, symbols)
# Generate one: openssl rand -base64 18
VITE_ADMIN_PASSWORD=your-super-strong-password-here-min-12-chars

# ============================================
# OPTIONAL: GitHub Auto-Save (client-side, runs in browser)
# ============================================
# Create a Fine-grained PAT at: https://github.com/settings/tokens
# Permissions: Contents (Read & Write) for this repository only
VITE_GITHUB_PAT=ghp_your_personal_access_token_here
VITE_GITHUB_REPO=fongway94/BMBCCWebpage
VITE_AUTO_SAVE_GITHUB=false

# ============================================
# FOR CLOUDFLARE PAGES DEPLOYMENT
# ============================================
# These are set in Cloudflare Pages Dashboard > Settings > Environment Variables
# NOT in this file (they're server-side secrets)

# ADMIN_PASSWORD=your-same-strong-password-here
# JWT_SECRET=generate-with: openssl rand -base64 32